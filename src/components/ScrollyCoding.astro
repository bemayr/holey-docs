---
import { changedLines, renderStep, SEVERITY_ICON } from './code-utils'
import type { Diagnostic, Step } from './code-utils'

interface Props {
  steps: Step[]
}

const { steps } = Astro.props

const rendered = await Promise.all(
  steps.map(async (step, i) => {
    const diff = i > 0 ? changedLines(steps[i - 1].code, step.code) : new Set<number>()
    const { html } = await renderStep(
      step.code,
      step.lang ?? 'typescript',
      step.diagnostics ?? [],
      diff
    )
    return { description: step.description, html, diagnostics: step.diagnostics ?? [] }
  })
)

const uid = `sc-${Math.random().toString(36).slice(2, 9)}`
---

<div class="scrollycoding" id={uid}>
  <div class="sc-steps">
    {
      rendered.map((step, i) => (
        <div class="sc-step" data-i={i}>
          <div class="sc-text" set:html={step.description} />
        </div>
      ))
    }
    <div class="sc-end-spacer"></div>
  </div>
  <div class="sc-panel">
    {
      rendered.map((step, i) => (
        <div class="sc-code" data-i={i}>
          <Fragment set:html={step.html} />
          {step.diagnostics.length > 0 && (
            <div class="sc-diag-panel">
              {step.diagnostics.map((d: Diagnostic) => (
                <div class={`sc-diag-item sc-diag-${d.severity}`}>
                  <span class="sc-diag-icon" aria-label={d.severity}>
                    {SEVERITY_ICON[d.severity]}
                  </span>
                  <span class="sc-diag-text">{d.message}</span>
                  <span class="sc-diag-line">Ln {d.line}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  ;(() => {
    function init() {
      const root = document.getElementById(uid)
      if (!root) return

      const steps = [...root.querySelectorAll('.sc-step')]
      const codes = [...root.querySelectorAll('.sc-code')]
      let activeIndex = -1

      function updateActive() {
        const mid = window.innerHeight / 2
        let best = 0
        let bestDist = Infinity
        steps.forEach((step, i) => {
          const rect = step.getBoundingClientRect()
          const dist = Math.abs((rect.top + rect.bottom) / 2 - mid)
          if (dist < bestDist) {
            bestDist = dist
            best = i
          }
        })
        if (best === activeIndex) return
        activeIndex = best
        codes.forEach((c, j) => c.classList.toggle('active', j === best))
        steps.forEach((s, j) => s.classList.toggle('active', j === best))
      }

      let ticking = false
      window.addEventListener(
        'scroll',
        () => {
          if (ticking) return
          ticking = true
          requestAnimationFrame(() => {
            updateActive()
            ticking = false
          })
        },
        { passive: true }
      )

      updateActive()
    }

    init()
    document.addEventListener('astro:page-load', init)
  })()
</script>

<style>
  .scrollycoding {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: start;
    margin-block: 2rem;
  }

  .sc-steps {
    min-width: 0;
    padding-inline-end: 0.5rem;
  }

  .sc-step {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-block: 3rem;
    padding-inline-start: 1.5rem;
    border-inline-start: 2px solid var(--sl-color-gray-5);
    transition: border-color 0.3s;
  }

  .sc-step.active {
    border-inline-start-color: var(--sl-color-accent);
  }

  .sc-text {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .sc-text :global(p) {
    margin-block: 0.6rem;
  }

  .sc-text :global(p:first-child) {
    margin-block-start: 0;
  }

  .sc-text :global(p:last-child) {
    margin-block-end: 0;
  }

  .sc-end-spacer {
    height: 40vh;
  }

  .sc-panel {
    min-width: 0;
    position: sticky;
    top: calc(var(--sl-nav-height, 3.5rem) + 1rem);
    display: grid;
    overflow: hidden;
  }

  /* Stack all code blocks in the same grid cell, fade between them */
  .sc-code {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    min-width: 0;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .sc-code.active {
    opacity: 1;
    pointer-events: auto;
  }

  .sc-code :global(pre) {
    border-radius: 0;
    padding: 1.25rem 1.75rem;
    margin: 0;
    overflow-x: auto;
  }

  .sc-code :global(code) {
    counter-reset: line-number;
    /* Suppress the \n text nodes Shiki places between .line spans.
       Inside <pre>, white-space:pre turns those newlines into forced line
       breaks even when the parent has line-height:0. Switching to
       white-space:normal collapses them; .line restores pre behaviour. */
    white-space: normal;
  }

  .sc-code :global(.line) {
    display: block;
    line-height: 1.6;
    white-space: pre;
  }

  .sc-code :global(.line)::before {
    counter-increment: line-number;
    content: counter(line-number);
    display: inline-block;
    width: 1.5rem;
    margin-inline-end: 1.25rem;
    text-align: right;
    color: var(--sl-color-gray-4);
    user-select: none;
    font-size: 0.85em;
  }

  /* Changed lines */
  .sc-code :global(.sc-changed) {
    background-color: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    margin-inline: -1.75rem;
    padding-inline-start: calc(1.75rem - 3px);
    padding-inline-end: 1.75rem;
    border-inline-start: 3px solid var(--sl-color-accent);
  }

  /* Diagnostic severity colours */
  .sc-code :global(.sc-diag-error)   { --sc-diag-color: #e5534b; }
  .sc-code :global(.sc-diag-warning) { --sc-diag-color: #d29922; }
  .sc-code :global(.sc-diag-info)    { --sc-diag-color: #58a6ff; }

  /* Diagnostic line: full-width tint + left border */
  .sc-code :global(.sc-diag-error),
  .sc-code :global(.sc-diag-warning),
  .sc-code :global(.sc-diag-info) {
    background-color: color-mix(in srgb, var(--sc-diag-color) 8%, transparent);
    margin-inline: -1.75rem;
    padding-inline-start: calc(1.75rem - 3px);
    padding-inline-end: 1.75rem;
    border-inline-start: 3px solid var(--sc-diag-color);
  }

  /* Gutter: colour the line number */
  .sc-code :global(.sc-diag-error)::before,
  .sc-code :global(.sc-diag-warning)::before,
  .sc-code :global(.sc-diag-info)::before {
    color: var(--sc-diag-color);
  }

  /* Squiggly underline only on the code tokens, not the line number */
  .sc-code :global(.sc-diag-content) {
    text-decoration: underline wavy var(--sc-diag-color);
    text-underline-offset: 3px;
  }

  /* ── Diagnostic panel ── */
  .sc-code :global(.sc-diag-panel) {
    border-top: 1px solid var(--sl-color-hairline);
  }

  .sc-code :global(.sc-diag-item) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.825rem;
    font-family: var(--sl-font, sans-serif);
    line-height: 1.5;
    background-color: color-mix(in srgb, var(--sc-diag-color) 6%, var(--sl-color-bg, #fff));
    border-inline-start: 3px solid var(--sc-diag-color);
  }

  .sc-code :global(.sc-diag-icon) {
    flex-shrink: 0;
    font-size: 0.75em;
    font-weight: 700;
    color: var(--sc-diag-color);
  }

  .sc-code :global(.sc-diag-text) {
    flex: 1;
    color: var(--sl-color-text);
  }

  .sc-code :global(.sc-diag-line) {
    flex-shrink: 0;
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.75em;
    color: var(--sc-diag-color);
    opacity: 0.75;
  }
</style>
