---
import { changedLines, renderStep, SEVERITY_ICON } from './code-utils'
import type { Diagnostic, Step } from './code-utils'

interface SpotlightStep extends Step {
  title: string
}

interface Props {
  steps: SpotlightStep[]
}

const { steps } = Astro.props

const rendered = await Promise.all(
  steps.map(async (step, i) => {
    const diff = i > 0 ? changedLines(steps[i - 1].code, step.code) : new Set<number>()
    const { html } = await renderStep(
      step.code,
      step.lang ?? 'typescript',
      step.diagnostics ?? [],
      diff
    )
    return {
      title: step.title,
      description: step.description,
      html,
      diagnostics: step.diagnostics ?? [],
    }
  })
)

const uid = `spl-${Math.random().toString(36).slice(2, 9)}`
---

<div class="spotlight" id={uid}>
  <div class="spl-cards">
    {
      rendered.map((step, i) => (
        <button
          class:list={['spl-card', { active: i === 0 }]}
          data-i={i}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <span class="spl-card-title">{step.title}</span>
          <span class="spl-card-desc" set:html={step.description} />
        </button>
      ))
    }
  </div>
  <div class="spl-panel">
    {
      rendered.map((step, i) => (
        <div class:list={['spl-code', { active: i === 0 }]} data-i={i}>
          <Fragment set:html={step.html} />
          {step.diagnostics.length > 0 && (
            <div class="sc-diag-panel">
              {step.diagnostics.map((d: Diagnostic) => (
                <div class={`sc-diag-item sc-diag-${d.severity}`}>
                  <span class="sc-diag-icon" aria-label={d.severity}>
                    {SEVERITY_ICON[d.severity]}
                  </span>
                  <span class="sc-diag-text">{d.message}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  ;(() => {
    function init() {
      const root = document.getElementById(uid)
      if (!root) return

      const cards = [...root.querySelectorAll('.spl-card')]
      const codes = [...root.querySelectorAll('.spl-code')]

      function activate(index) {
        cards.forEach((c, i) => {
          c.classList.toggle('active', i === index)
          c.setAttribute('aria-pressed', String(i === index))
        })
        codes.forEach((c, i) => c.classList.toggle('active', i === index))
      }

      cards.forEach((card, i) => {
        card.addEventListener('click', () => activate(i))
      })

      activate(0)
    }

    init()
    document.addEventListener('astro:page-load', init)
  })()
</script>

<style>
  .spotlight {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: start;
    margin-block: 2rem;
  }

  /* ── Left: clickable cards ── */
  .spl-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .spl-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-align: start;
    width: 100%;
    padding: 0.875rem 1.125rem;
    background: transparent;
    border: 2px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .spl-card:hover:not(.active) {
    border-color: var(--sl-color-gray-3);
  }

  .spl-card.active {
    border-color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 6%, transparent);
  }

  .spl-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-text);
    line-height: 1.4;
  }

  .spl-card-desc {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
  }

  .spl-card-desc :global(p) {
    margin: 0;
  }

  /* ── Right: sticky code panel ── */
  .spl-panel {
    position: sticky;
    top: calc(var(--sl-nav-height, 3.5rem) + 1rem);
    display: grid;
    overflow: hidden;
  }

  .spl-code {
    grid-area: 1 / 1;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    min-width: 0;
  }

  .spl-code.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Square off bottom corners when a diagnostic panel follows */
  .spl-code :global(pre:has(+ .sc-diag-panel)) {
    border-radius: 0.5rem 0.5rem 0 0;
  }

  .spl-code :global(pre) {
    border-radius: 0.5rem;
    padding: 1rem 1.5rem;
    margin: 0;
    overflow-x: auto;
  }

  .spl-code :global(code) {
    counter-reset: line-number;
    white-space: normal;
  }

  .spl-code :global(.line) {
    display: block;
    line-height: 1.6;
    white-space: pre;
  }

  .spl-code :global(.line)::before {
    counter-increment: line-number;
    content: counter(line-number);
    display: inline-block;
    width: 1.5rem;
    margin-inline-end: 1.25rem;
    text-align: right;
    color: var(--sl-color-gray-4);
    user-select: none;
    font-size: 0.85em;
  }

  /* Changed lines */
  .spl-code :global(.sc-changed) {
    background-color: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    margin-inline: -1.5rem;
    padding-inline-start: calc(1.5rem - 3px);
    padding-inline-end: 1.5rem;
    border-inline-start: 3px solid var(--sl-color-accent);
  }

  /* Diagnostic severity colours */
  .spl-code :global(.sc-diag-error)   { --sc-diag-color: #e5534b; }
  .spl-code :global(.sc-diag-warning) { --sc-diag-color: #d29922; }
  .spl-code :global(.sc-diag-info)    { --sc-diag-color: #58a6ff; }

  .spl-code :global(.sc-diag-error),
  .spl-code :global(.sc-diag-warning),
  .spl-code :global(.sc-diag-info) {
    background-color: color-mix(in srgb, var(--sc-diag-color) 8%, transparent);
    margin-inline: -1.5rem;
    padding-inline-start: calc(1.5rem - 3px);
    padding-inline-end: 1.5rem;
    border-inline-start: 3px solid var(--sc-diag-color);
  }

  .spl-code :global(.sc-diag-error)::before,
  .spl-code :global(.sc-diag-warning)::before,
  .spl-code :global(.sc-diag-info)::before {
    color: var(--sc-diag-color);
  }

  .spl-code :global(.sc-diag-content) {
    text-decoration: underline wavy var(--sc-diag-color);
    text-underline-offset: 3px;
  }

  /* ── Diagnostic panel ── */
  .spl-code :global(.sc-diag-panel) {
    border: 1px solid var(--sl-color-gray-5);
    border-top: none;
    border-radius: 0 0 0.5rem 0.5rem;
    overflow: hidden;
  }

  .spl-code :global(.sc-diag-item) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    font-size: 0.825rem;
    font-family: var(--sl-font, sans-serif);
    line-height: 1.5;
    background-color: color-mix(in srgb, var(--sc-diag-color) 6%, var(--sl-color-bg, #fff));
    border-inline-start: 3px solid var(--sc-diag-color);
  }

  .spl-code :global(.sc-diag-icon) {
    flex-shrink: 0;
    font-size: 0.75em;
    font-weight: 700;
    color: var(--sc-diag-color);
  }

  .spl-code :global(.sc-diag-text) {
    color: var(--sl-color-text);
  }
</style>
